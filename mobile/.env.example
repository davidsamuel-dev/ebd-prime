# Copie para `mobile/.env` (o ficheiro real não vai para o git).
# Reinicie o bundler após alterar: npx expo start -c
#
# Prefixo obrigatório no cliente Expo: EXPO_PUBLIC_
# (não use variáveis sem este prefixo — não entram no bundle.)

# --- API PHP + MySQL (Hostinger ou local) ---
EXPO_PUBLIC_API_URL=https://ebd.adparaiso.com.br

# Central de ajuda: {EXPO_PUBLIC_API_URL}/ajuda.html (derivado automaticamente no app)

# Desenvolvimento local (emulador Android):
# EXPO_PUBLIC_API_URL=http://10.0.2.2:8080
