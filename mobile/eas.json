{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_DATA_BACKEND": "rest",
        "EXPO_PUBLIC_API_URL": "https://ebd.adparaiso.com.br"
      }
    },
    "production": {
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_DATA_BACKEND": "rest",
        "EXPO_PUBLIC_API_URL": "https://ebd.adparaiso.com.br"
      }
    }
  }
}
