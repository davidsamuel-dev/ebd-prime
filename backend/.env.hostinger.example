# =============================================================================
# EBD Prime — produção Hostinger (copiar para `.env` NO SERVIDOR via FTP/hPanel)
# Nunca commitar o `.env` real com passwords.
# =============================================================================

# MySQL — dois cenários:
# A) PHP na Hostinger (FTP, ebd.adparaiso.com.br): use 127.0.0.1 (como no hPanel)
# B) Scripts no teu PC (php test-hostinger-db.php): host remoto + Remoto MySQL ativo no hPanel
#    Host remoto costuma ser auth-dbXXXX.hstgr.io (igual ao phpMyAdmin, sem /index.php)
EBD_DB_HOST=127.0.0.1
EBD_DB_PORT=3306
EBD_DB_NAME=u370088447_ebd_prime
EBD_DB_CHARSET=utf8mb4
EBD_DB_USER=u370088447_adparaiso
EBD_DB_PASS="coloque_a_senha_entre_aspas_se_tiver_#"

# Ligação remota a partir do PC (opcional; ativar IP em hPanel → Remoto MySQL):
# EBD_DB_HOST=auth-db1664.hstgr.io

# CORS: URL do site ou do Expo web em produção (vazio = * em dev)
EBD_CORS_ORIGIN=

# Recuperação de senha — link público do reset-form.php
EBD_PASSWORD_RESET_LINK_BASE=https://ebd.adparaiso.com.br/api/auth/reset-form.php

# SMTP Hostinger Email (hPanel → E-mails → criar caixa, ex. suporte@adparaiso.com.br)
# Servidor: smtp.hostinger.com | 465 SSL (recomendado) ou 587 + tls
EBD_SMTP_HOST=smtp.hostinger.com
EBD_SMTP_PORT=465
EBD_SMTP_SECURE=ssl
EBD_SMTP_USER=suporte@ebd.adparaiso.com.br
EBD_SMTP_PASS="senha_da_caixa_de_email"
EBD_SMTP_FROM_EMAIL=suporte@ebd.adparaiso.com.br
EBD_SMTP_FROM_NAME=EBD Prime

# Deep link para voltar ao app após redefinir senha (scheme em mobile/app.json)
EBD_APP_LOGIN_DEEP_LINK=mobile://login

# SMS onboarding: omitir = código devolvido na API (sem gateway real)
# EBD_SMS_REAL=1
