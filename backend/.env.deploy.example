# =============================================================================
# Deploy automático para Hostinger (FTP/FTPS) — copie para backend/.env.deploy
# Nunca commitar backend/.env.deploy (está no .gitignore).
# Credenciais: hPanel → Websites → ebd.adparaiso.com.br → Ficheiros → FTP Accounts
# =============================================================================

# Servidor FTP (hPanel → Websites → FTP Accounts)
HOSTINGER_FTP_HOST=ftp.seudominio.com.br

HOSTINGER_FTP_PORT=21

# Utilizador FTP criado no hPanel (ex.: u123456789.seudominio.com.br)
HOSTINGER_FTP_USER=seu_usuario_ftp
HOSTINGER_FTP_PASS="sua_senha_ftp"

# Pasta remota na raiz do site (geralmente / ou public_html)
HOSTINGER_FTP_REMOTE_DIR=/

# true = FTPS (recomendado na Hostinger); false = FTP simples
HOSTINGER_FTP_SECURE=true

# Opcional: só enviar API (pasta api + lib + vendor + .env + index.php...)
# false = envia todo o pacote gerado em deploy/hostinger-ebd.adparaiso.com.br/
HOSTINGER_FTP_API_ONLY=false
