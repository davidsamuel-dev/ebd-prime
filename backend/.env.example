# =============================================================================
# EBD Prime — backend PHP / MySQL
# Copiar para `.env` na pasta `backend/` (o PHP carrega este ficheiro automaticamente).
# =============================================================================

# --- Opção A: MySQL em Docker (raiz do projeto: `docker compose up -d`) ---
EBD_DB_HOST=127.0.0.1
EBD_DB_PORT=3306
EBD_DB_NAME=ebd_prime
EBD_DB_CHARSET=utf8mb4
EBD_DB_USER=ebd
EBD_DB_PASS=ebd_local

# --- Opção B: XAMPP / WAMP / MariaDB instalado no Windows (exemplo root sem senha) ---
# EBD_DB_HOST=127.0.0.1
# EBD_DB_PORT=3306
# EBD_DB_NAME=ebd_prime
# EBD_DB_CHARSET=utf8mb4
# EBD_DB_USER=root
# EBD_DB_PASS=

# CORS: origem do Expo web ou domínio em produção. Vazio = * (ok em desenvolvimento).
EBD_CORS_ORIGIN=

# --- Produção Hostinger: ver também backend/.env.hostinger.example e docs/migracao-hostinger.md ---

# SMS no cadastro (onboarding): omitir ou 0 = simulação (código na resposta JSON, sem gateway).
# Definir 1 quando integrar envio real por SMS (Twilio, etc.).
# EBD_SMS_REAL=

# --- Recuperação de senha (PHPMailer — SMTP Hostinger ou similar) ---
# URL pública do script reset-form.php (link no e-mail). Ex.:
# EBD_PASSWORD_RESET_LINK_BASE=https://seudominio.com/api/auth/reset-form.php
EBD_PASSWORD_RESET_LINK_BASE=
EBD_SMTP_HOST=smtp.hostinger.com
EBD_SMTP_PORT=465
# ssl = SMTPS (465) | tls ou starttls = porta 587
EBD_SMTP_SECURE=ssl
EBD_SMTP_USER=suporte@adparaiso.com.br
EBD_SMTP_PASS=
EBD_SMTP_FROM_EMAIL=suporte@adparaiso.com.br
EBD_SMTP_FROM_NAME=EBD Prime
