{
  "name": "ebd-prime",
  "private": true,
  "description": "EBD Prime — API PHP + app Expo. MySQL (Hostinger ou local).",
  "scripts": {
    "db:import": "powershell -NoProfile -ExecutionPolicy Bypass -File ./backend/scripts/import-schema.ps1",
    "db:import:php": "php backend/scripts/import-schema.php",
    "db:check": "php backend/scripts/check-db.php",
    "db:seed:demo": "php backend/scripts/seed-demo-turmas-alunos.php",
    "doctor": "php backend/scripts/doctor.php",
    "api": "php -S 0.0.0.0:8080 -t backend backend/router-dev.php",
    "db:test:remote": "php backend/scripts/test-hostinger-db.php",
    "deploy:hostinger": "node scripts/deploy-hostinger.mjs",
    "deploy:hostinger:dry": "node scripts/deploy-hostinger.mjs --dry-run",
    "deploy:hostinger:pack": "node scripts/deploy-hostinger.mjs --pack-only",
    "deploy:landing": "node scripts/upload-landing.mjs",
    "deploy:landing:assets": "node scripts/upload-landing-api.mjs",
    "deploy:all": "npm run deploy:hostinger && npm run deploy:landing && npm run deploy:landing:assets",
    "build:apk": "cd mobile && npm run build:apk",
    "verify:git": "node scripts/verify-git-safe.mjs"
  },
  "devDependencies": {
    "basic-ftp": "^5.0.5",
    "mysql2": "^3.14.1"
  }
}
